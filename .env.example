# === Mission Control 환경변수 ===

# 인증 비밀번호 (필수! 반드시 변경하세요)
MC_PASSWORD=change-me-now

# JWT 시크릿 (랜덤 문자열 권장)
MC_JWT_SECRET=my-super-secret-key-change-this

# 텔레그램 알림 설정
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# 데이터 모드: "sqlite" 또는 "json" (기본값: json)
DATA_MODE=sqlite
